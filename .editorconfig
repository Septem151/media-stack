# Editor defaults mirroring the tool configs (see pyproject.toml). For vim/kate/etc.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
max_line_length = 88

[*.py]
indent_size = 4

[*.{yaml,yml,xml,json,toml}]
indent_size = 2

[nginx/**]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
