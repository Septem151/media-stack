# Copy to ".env" and fill in the deployment section at the bottom. API keys are
# appended automatically on first run.

# Per-service UIDs (shared media GID). `stack setup` creates the matching users.
MEDIA_GID=13000
QBIT_UID=13001
SONARR_UID=13002
RADARR_UID=13003
PROWLARR_UID=13004
JELLYFIN_UID=13005
RECYCLARR_UID=13006
DDCLIENT_UID=13007
SLSKD_UID=13008
PICARD_UID=13009

# LAN
LAN_SUBNET=10.0.0.0/24

# Service ports (LAN-only; the firewall, compose, and nginx all read these)
QBIT_WEBUI_PORT=8080
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
JELLYFIN_PORT=8096
SLSKD_PORT=5030
PICARD_PORT=5800
PIHOLE_WEBUI_PORT=8082

# App defaults. Quote values with spaces — this file is sourced by bash too.
JELLYFIN_SERVER_NAME="Home Media"
DDNS_HOST=@
#TZ=America/Chicago

# --- Deployment values + secrets (fill these in) ---------------------------

# Public domain / TLS. The apex (DOMAIN) and JELLYFIN_HOSTNAME both serve Jellyfin;
# the Let's Encrypt cert is a SAN over both. They may be equal (apex-only serving).
DOMAIN=example.com
JELLYFIN_HOSTNAME=jellyfin.example.com
LETSENCRYPT_EMAIL=you@example.com

# This server's LAN IP (LAN-only ports bind here; *.lan names resolve to it).
LAN_IP=10.0.0.60

# Media + downloads root (single filesystem -> import hardlinks).
DATA_ROOT=/data

# Mullvad WireGuard (from your Mullvad account).
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.0.0.2/32
MULLVAD_CITIES=Amsterdam

# Namecheap dynamic DNS password (Domain List -> Manage -> Advanced DNS).
NAMECHEAP_DDNS_PASSWORD=
