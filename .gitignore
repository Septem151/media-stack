# Secrets
.env

# Runtime application state (databases, logs, caches) — reproduced from seed/
appdata/

# Generated certs
certs/

# Rendered nginx config (regenerated by `stack up` from the template)
nginx/conf.d/

# Media + downloads live outside the repo, but ignore if DATA_ROOT points inside
data/

# Python bytecode cache (scripts/ CLI)
__pycache__/
